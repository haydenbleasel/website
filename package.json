{
  "name": "haydenbleasel-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "types": "turbo types",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "bump-deps": "npx npm-check-updates -u --deep && bun i",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=haydenbleasel && changeset publish",
    "prepare": "husky"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.13.0",
    "os": "^0.1.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "cli": "^1.0.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "ultracite": "7.5.5"
  },
  "packageManager": "bun@1.3.12",
  "patchedDependencies": {
    "next-themes@0.4.6": "patches/next-themes@0.4.6.patch"
  }
}
